// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider     = "prisma-client"
    moduleFormat = "esm"
    output       = "../src/generated/prisma"
}

datasource db {
    // Para SQLite (Padrão)
    provider = "sqlite"
}

model Project {
    id          String    @id @default(uuid())
    name        String    @unique
    cwd         String    // Current Working Directory
    mainFile    String?   // Entrypoint (index.js, ecosystem.config.js, etc)
    envPath     String?   // Path to .env file relative to cwd or absolute
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime? @updatedAt @map("updated_at")

    processes   Process[]

    @@map("projects")
}

model Process {
    id          String    @id @default(uuid())
    name        String    @unique
    projectId   String    @map("project_id")
    status      String?   // status cached? Or we just read from PM2
    config      String?   // JSON string with more pm2 config if needed
    
    project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime? @updatedAt @map("updated_at")

    @@map("processes")
}